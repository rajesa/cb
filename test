!
ip prefix-list PL-ALL-MGSFW-RCV seq 10 permit 0.0.0.0/0
!
route-map RMAP-ALL-MGSFW-RCV permit 10
  match ip address prefix-list PL-ALL-MGSFW-RCV
  set local-preference 200
!
ip as-path access-list ASP-LOCAL seq 10 permit "^$"
ip prefix-list PL-HOST-ROUTES seq 5 permit 0.0.0.0/0 eq 32
!
route-map RMAP-ALL-MGSFW-ADV permit 10
  match as-path ASP-LOCAL
route-map RMAP-ALL-MGSFW-ADV deny 20
  match ip address prefix-list PL-HOST-ROUTES 
!
ip as-path access-list ASP-LOCALAS seq 5 permit "_65104$"
ip prefix-list PL-INFRA-MGSFW-ADV seq 10 permit 0.0.0.0/0
!
route-map RMAP-INFRA-MGSFW-ADV permit 10
  match ip address prefix-list PL-INFRA-MGSFW-ADV 
route-map RMAP-INFRA-MGSFW-RCV permit 10
  match as-path ASP-LOCALAS
!
router bgp 65101
  template peer ptmp-mgsfw-all
    bfd multihop
    remote-as 65103
    password 3 3974ec3f0e842eacc1fc497b934ce29e
    ebgp-multihop 10
    address-family ipv4 unicast
      route-map RMAP-ALL-MGSFW-RCV in
      route-map RMAP-ALL-MGSFW-ADV out
  vrf ops-control
    address-family ipv4 unicast
    neighbor 10.224.11.41
      inherit peer ptmp-mgsfw-all
      description ops-control_mgsfw
      local-as 65104 no-prepend replace-as
      update-source loopback102
  vrf ops-data
    address-family ipv4 unicast
    neighbor 10.224.11.49
      inherit peer ptmp-mgsfw-all
      description ops-data_mgsfw
      local-as 65104 no-prepend replace-as
      update-source loopback103
  vrf ocp-control
    address-family ipv4 unicast
    neighbor 10.224.11.57
      inherit peer ptmp-mgsfw-all
      description ocp-control_mgsfw
      local-as 65104 no-prepend replace-as
      update-source loopback104
  vrf shared-infra
    address-family ipv4 unicast
    neighbor 10.224.11.33
      remote-as 65103
      local-as 65102 no-prepend replace-as
      description shared-infra_mgsfw
      password 3 3974ec3f0e842eacc1fc497b934ce29e
      update-source loopback101
      ebgp-multihop 10
      bfd multihop
      address-family ipv4 unicast
        route-map RMAP-INFRA-MGSFW-RCV in
        route-map RMAP-INFRA-MGSFW-ADV out
!
